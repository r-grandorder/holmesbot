DISCORD_BOT_TOKEN=
DISCORD_APPLICATION_ID=
DISCORD_CLIENT_SECRET=
# Local dev only. With docker-compose the image keeps the SQLite DB on the /data volume.
DATABASE_URL=sqlite:./database/holmesbot.sqlite3
GUILD_IDS=
HEALTH_PORT=8080
LOG_LEVEL=INFO
# Public base URL of the S3 assets bucket (silhouettes for /guess_shadow), e.g.
# https://bunyanbot-assets-327760835875.s3.us-east-1.amazonaws.com
ASSETS_BASE_URL=
