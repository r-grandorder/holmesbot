DISCORD_BOT_TOKEN=
DISCORD_APPLICATION_ID=
DISCORD_CLIENT_SECRET=
# Local dev only. With docker-compose the image keeps the SQLite DB on the /data volume.
DATABASE_URL=sqlite:./database/holmesbot.sqlite3
GUILD_IDS=
HEALTH_PORT=8080
LOG_LEVEL=INFO
# Public base URL of the S3 assets bucket (silhouettes for /guess_shadow), e.g.
# https://bunyanbot-assets-327760835875.s3.us-east-1.amazonaws.com
ASSETS_BASE_URL=
# Custom QP currency emote for THIS bot application, e.g. <:qp:123456789012345678>
# (upload it under the app's emojis). Falls back to plain "QP" if unset.
QP_EMOTE=
# Repost the active game prompt after this many channel messages, so it doesn't
# scroll out of view (0 = never repost; try ~10 for a busy channel).
REPOST_AFTER=0
